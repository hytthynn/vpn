{
  "functions": {
    "api/proxy.js":   { "maxDuration": 10 },
    "api/webhook.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/proxy",   "destination": "/api/proxy.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
